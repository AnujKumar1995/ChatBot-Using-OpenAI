# OpenAI API Key (required) - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Fine-tuned model ID (optional) - set after fine-tuning completes
# OPENAI_FINE_TUNED_MODEL=ft:gpt-4o-mini-2024-07-18:your-org::job-id

# Company name shown in system prompt
COMPANY_NAME=Our Company

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=False
MAX_TOKENS=2000
TEMPERATURE=0.7
RATE_LIMIT_PER_MINUTE=30

